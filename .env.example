# AI Sticker Generator - 完整环境变量配置
# Copy this file to .env.local and fill in values

# ============================================
# 必需 - 图片生成API（三选一，优先级从高到低）
# ============================================

# Option 1: Replicate (推荐，Flux Schnell，~$0.003/张)
# 注册: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Option 2: OpenAI (备选，~$0.04/张)
# 注册: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Option 3: Pollinations (免费，无需key，质量较低)
# 无需配置，前两者都没配时自动使用

# ============================================
# 必需 - Supabase 数据库
# ============================================
# 注册: https://supabase.com → Create Project
# SQL Editor 中执行 supabase/migrations/001_initial.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# 必需 - 认证
# ============================================
# 生成: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com → APIs → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers → New OAuth App)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================
# 可选 - Creem 支付（已接入，主支付通道）
# ============================================
# 注册: https://creem.io → Dashboard → API Keys
CREEM_API_KEY=

# Creem 产品ID（Dashboard → Products → Create 后获取）
CREEM_PRO_MONTHLY_PRODUCT_ID=    # $9.9/月 Pro 计划
CREEM_PRO_YEARLY_PRODUCT_ID=     # $79/年 Pro 计划

# Creem Webhook 签名密钥（Settings → Webhooks → 创建后获取）
CREEM_WEBHOOK_SECRET=

# ============================================
# 可选 - Stripe 支付（备用，香港账户）
# ============================================
# 注册: https://stripe.com → Get API Keys（备用方案）
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe 价格ID（Dashboard → Products → Create后获取）
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=

# ============================================
# 可选 - 站点配置
# ============================================
NEXT_PUBLIC_SITE_URL=https://aisticker.pics
ADMIN_EMAILS=your-email@example.com

# ============================================
# 可选 - 分析和广告
# ============================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
